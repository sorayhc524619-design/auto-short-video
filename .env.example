# ===================================================
# .env.example - 環境変数設定テンプレート
# このファイルをコピーして .env にリネームし、値を設定してください。
# .env は .gitignore に追加してGitにコミットしないでください。
# ===================================================

# ===== 必須 =====
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== YouTube（必須 / 投稿する場合）=====
# Google Cloud ConsoleでOAuth2クライアントを作成し、認証後に取得
YOUTUBE_CREDENTIALS_JSON={"token":"ya29.xxx","refresh_token":"1//xxx","client_id":"xxx.apps.googleusercontent.com","client_secret":"GOCSPX-xxx","token_uri":"https://oauth2.googleapis.com/token","scopes":["https://www.googleapis.com/auth/youtube.upload"]}

# ===== TikTok（必須 / 投稿する場合）=====
# https://developers.tiktok.com で取得
TIKTOK_ACCESS_TOKEN=act.xxxxxxxxxxxxxxxx

# ===== 音声生成（どちらか1つ）=====
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOICEVOX_URL=http://localhost:50021

# ===== 映像生成（どちらか1つ）=====
KLING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== コンテンツ設定 =====
CONTENT_GENRE=雑学・豆知識
# 選択肢: 雑学・豆知識 / テクノロジー / ビジネス / エンタメ / ニュース

# ===== 任意設定 =====
LOG_LEVEL=INFO
VIDEO_DURATION_SEC=60
