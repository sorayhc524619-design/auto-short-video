# ===================================================
# .env.example - 環境変数設定テンプレート
# US向け Cinematic Sleep Music YouTubeチャンネル用
# このファイルをコピーして .env にし、値を設定してください
# .env は .gitignore に追加してコミットしないこと
# ===================================================

# ===== 必須: Claude API（テーマ生成） =====
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== 必須: Suno API（音楽生成）=====
# サードパーティ提供（公式 Suno に直接 API はない）。
# 例: https://sunoapi.org / https://aimlapi.com / https://apipass.io
# 商用利用には Suno Pro ($10/mo) 以上のアカウントが必須
SUNO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUNO_API_BASE_URL=https://api.sunoapi.org
SUNO_MODEL=V5
SUNO_INSTRUMENTAL=true

# ===== 必須: Stability AI（ビジュアル画像生成）=====
# https://platform.stability.ai/ で取得
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== 必須: YouTube OAuth2（投稿）=====
# setup_youtube_auth.py を一度実行してJSONを取得 → ここに丸ごと貼る
YOUTUBE_CREDENTIALS_JSON={"token":"ya29.xxx","refresh_token":"1//xxx","client_id":"xxx.apps.googleusercontent.com","client_secret":"GOCSPX-xxx","token_uri":"https://oauth2.googleapis.com/token","scopes":["https://www.googleapis.com/auth/youtube.upload","https://www.googleapis.com/auth/youtube"]}
YOUTUBE_PRIVACY_STATUS=public

# ===== チャンネル設定 =====
CHANNEL_NICHE=Cinematic Sleep Music
# 動画の長さ（秒）。テスト時は 600 (10分)、本番は 10800 (3h) 〜 28800 (8h) 推奨
VIDEO_DURATION_SEC=10800
# 1動画あたりの曲数（連結しループ）
MUSIC_TRACKS_PER_VIDEO=5
MUSIC_CROSSFADE_SEC=6
AMBIENT_VOLUME=0.35
MUSIC_VOLUME=0.85

# ===== 任意 =====
LOG_LEVEL=INFO
FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
